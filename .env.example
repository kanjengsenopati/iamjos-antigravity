APP_NAME="IamJOS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://ejournal.apdesyi.or.id
APP_API_KEY=                      # Kunci API internal untuk endpoint yang dilindungi

# ============================================================
# IAMJOS INSTANCE CONFIGURATION
# Setiap instance IAMJOS harus memiliki INSTANCE_ID yang unik.
# Nilai ini digunakan sebagai prefix untuk Redis keys dan queue
# names untuk menghindari konflik antar instance yang berbagi
# Redis server yang sama (multi-instance deployment).
# Contoh: iamjos-jurnal-xyz, iamjos-univ-abc
# ============================================================
IAMJOS_INSTANCE_ID=iamjos-instance-1

# ============================================================
# IAMJOS LICENSE CONFIGURATION
# IAMJOS_LICENSE_CHECK_ENABLED: Set ke 'true' untuk mengaktifkan
# validasi lisensi ke KAMPUS. Default 'false' — semua fitur aktif.
# IAMJOS_KAMPUS_URL: URL server KAMPUS (Kantor Manajemen Pusat IamJOS).
#   Disediakan oleh tim IamJOS saat aktivasi lisensi.
# IAMJOS_LICENSE_KEY: Kunci lisensi unik per instance.
#   Hubungi support@iamjos.id untuk mendapatkan kunci lisensi.
# ============================================================
IAMJOS_LICENSE_CHECK_ENABLED=false
IAMJOS_KAMPUS_URL=                # Disediakan oleh tim IamJOS saat aktivasi
IAMJOS_LICENSE_KEY=               # Hubungi support@iamjos.id untuk mendapatkan kunci lisensi

# ============================================================
# IAMJOS SUPER ADMIN CREDENTIALS
# Diisi sebelum menjalankan: php artisan db:seed
# ============================================================
SUPER_ADMIN_EMAIL=superadmin@iamjos.id
SUPER_ADMIN_NAME="Super Administrator"
# Jika dikosongkan, password akan di-generate otomatis dan
# ditampilkan di console saat seeding. CATAT passwordnya!
SUPER_ADMIN_PASSWORD=

# Password untuk demo users (dev/staging only — JANGAN di production!)
DEMO_USER_PASSWORD=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================================
# DATABASE
# Development: SQLite (zero-setup, tidak perlu instalasi)
# Production: PostgreSQL (wajib untuk performa dan skalabilitas)
# ============================================================
DB_CONNECTION=sqlite
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=iamjos
# DB_USERNAME=postgres
# DB_PASSWORD=secret

# ============================================================
# REDIS CONFIGURATION
# Development: bisa dikosongkan (akan fallback ke database driver)
# Production: WAJIB dikonfigurasi untuk performa optimal.
#
# IAMJOS menggunakan 3 database Redis terpisah:
#   REDIS_DB=0        → Queue dan koneksi default
#   REDIS_CACHE_DB=1  → Cache aplikasi
#   REDIS_SESSION_DB=2 → Session pengguna
#
# Jika beberapa instance IAMJOS berbagi satu Redis server,
# pastikan IAMJOS_INSTANCE_ID berbeda untuk setiap instance.
# ============================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=               # WAJIB diisi di production untuk keamanan!
REDIS_PORT=6379
REDIS_DB=0                    # Database untuk queue dan koneksi default
REDIS_CACHE_DB=1              # Database untuk cache (harus berbeda dari REDIS_DB)
REDIS_SESSION_DB=2            # Database untuk session (harus berbeda dari keduanya)

# ============================================================
# DRIVER CONFIGURATION
# Development: gunakan 'database' untuk zero-setup
# Production: gunakan 'redis' untuk performa optimal
# ============================================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_CONNECTION=session

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=               # Otomatis menggunakan IAMJOS_INSTANCE_ID sebagai prefix

MEMCACHED_HOST=127.0.0.1

# ============================================================
# MAIL CONFIGURATION
# ============================================================
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Untuk testing dengan Mailtrap:
# MAIL_MAILER=smtp
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=your-mailtrap-username
# MAIL_PASSWORD=your-mailtrap-password
# MAIL_ENCRYPTION=tls

# ============================================================
# AWS S3 (Opsional — untuk file storage di production)
# Direkomendasikan untuk deployment multi-server.
# Set IAMJOS_FILES_DISK=s3 untuk mengaktifkan S3 storage.
# Kompatibel dengan: AWS S3, MinIO, Cloudflare R2, DigitalOcean Spaces
# ============================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_URL=                          # URL publik bucket (opsional, untuk CDN)
AWS_ENDPOINT=                     # Custom endpoint untuk MinIO/R2 (opsional)
AWS_USE_PATH_STYLE_ENDPOINT=false # Set true untuk MinIO

# Driver untuk file submission/galley/avatar
# Development: local (default, tidak perlu konfigurasi)
# Production:  s3 (membutuhkan AWS_* vars di atas)
IAMJOS_FILES_DISK=local

VITE_APP_NAME="${APP_NAME}"

# ============================================================
# ERROR TRACKING (Sentry)
# Untuk monitoring error di production.
# Install: composer require sentry/sentry-laravel
# Dapatkan DSN dari: https://sentry.io
# ============================================================
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1    # 10% performance monitoring
SENTRY_PROFILES_SAMPLE_RATE=0.1
