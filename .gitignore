# Storage directories — isi tidak di-commit, tapi struktur direktori dipertahankan via .gitkeep
/storage/framework/cache/data/*
!/storage/framework/cache/data/.gitkeep
/storage/framework/sessions/*
!/storage/framework/sessions/.gitkeep
/storage/framework/views/*
!/storage/framework/views/.gitkeep
/storage/logs/*
!/storage/logs/.gitkeep
/bootstrap/cache/*
!/bootstrap/cache/.gitkeep

# Dumps and temporary files
*.sql
*.sql.gz
*.tar.gz
/scratch/

# ============================================================
# IAMJOS — File sensitif yang tidak boleh masuk repository
# ============================================================

# Script test ad-hoc di root (gunakan tests/ untuk test yang proper)
test_*.php
scratch_*.php

# Environment files — hanya .env.example yang boleh di-commit
.env.*
!.env.example

# File temporary health check
health-check-probe.tmp

# Database dump directories
/db_*/
/iamjoss.sql/

# Dev scratch/test scripts (root-level)
test_*.php
scratch_*.php