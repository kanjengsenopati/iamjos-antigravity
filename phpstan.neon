includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 5
    reportUnmatchedIgnoredErrors: false
    paths:
        - app

    # Abaikan error yang umum di Laravel karena magic methods
    ignoreErrors:
        # Eloquent Builder magic methods
        - '#Call to an undefined method Illuminate\\Database\\Eloquent\\Builder#'
        - '#Call to an undefined method Illuminate\\Database\\Query\\Builder#'
        # Facade static calls
        - '#Static call to instance method#'
        # Larastan internal — SessionStore compatibility
        - '#Call to an undefined method Illuminate\\Session\\Store::setConnection#'
        - '#Call to an undefined method Illuminate\\Cache\\[A-Za-z]+Store::#'
